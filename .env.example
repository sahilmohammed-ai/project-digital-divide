# Copy this file to ".env" for local development (vercel dev),
# and add the same variables in your Vercel project settings for production.

# Resend API key — sign up at https://resend.com using projectdigitaldivide.org@gmail.com
# (so the free tier can email that inbox without a verified domain).
RESEND_API_KEY=re_your_api_key_here

# Optional overrides (sensible defaults are built in):
# TO_EMAIL=projectdigitaldivide.org@gmail.com
# FROM_EMAIL=Project Digital Divide <onboarding@resend.dev>
